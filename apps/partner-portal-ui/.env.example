# Base URL for the Ops/Partner BFF aggregation API.
# All client fetches go through Next.js rewrite /api/* -> ${NEXT_PUBLIC_BFF_BASE_URL}/*.
NEXT_PUBLIC_BFF_BASE_URL=http://localhost:8095

# Local-dev mock-auth: partner id sent as X-Partner-Id header by the API client.
# In production this is resolved server-side from the partner's HMAC-authenticated session.
NEXT_PUBLIC_PARTNER_ID=PARTNER_LOCAL_DEV
