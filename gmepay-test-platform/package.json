{
  "name": "gmepay-test-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Independent use-case acceptance test platform for GMEPay+ (separate from the Pay+ codebase).",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm:api\" \"npm:web\"",
    "api": "tsx watch src/server.ts",
